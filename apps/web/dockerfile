# Node image (build from monorepo root: docker build -f apps/web/dockerfile .)

FROM node:22-bookworm-slim

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Full workspace context for pnpm workspaces + lockfile
COPY . .

# Install deps and generate Prisma client as root (Corepack writes under root/cache).
RUN pnpm install --frozen-lockfile
RUN pnpm prisma:generate

# Non-root runtime: writable home avoids Corepack EACCES when `pnpm dev` runs.
RUN useradd -r -u 1001 -m appuser && chown -R appuser:appuser /app
USER appuser

# Expose the port the application will run on.
EXPOSE 3000

# Start the application.
CMD ["pnpm", "--filter", "@prove-it/web", "dev", "--hostname", "0.0.0.0"]
