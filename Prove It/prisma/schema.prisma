// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  // Application user: profile, credentials, and optional university affiliation.
  //
  // Primary identifiers:
  // - privateId is the internal surrogate key (never expose in public APIs).
  // - publicId is an immutable, opaque id safe to share in URLs and responses.
  privateId                     Int                             @Id @default(autoincrement())
  publicId                      String                          @unique @default(cuid())

  // Profile and sign-in:
  // Display name; username (unique URL slug); unique email; bcrypt-hashed password;
  // optional bio and avatar image URL.
  name                          String
  username                      String                          @unique
  email                         String                          @unique
  password                      String
  bio                           String?
  avatarUrl                     String?

  // Optional link to the university the user is associated with (tenant context).
  privateUniversityId           Int?
  university                    University                      @relation(fields: [privateUniversityId], [privateId], onDelete: SetNull)

  // Inverse relations: rows in other tables whose foreign keys reference this user’s privateId. Prisma Needs this to work. Not columns in the database
  oauthAccounts                 OAuthAccount[]
  sessions                      Sessions[]
  documents                     Document[]
  enrollments                   userCourse[]
  dailyUsages                   DailyUsage[]
  subscriptions                 Subscription[]

  // Lifecycle: last successful login; record creation time; soft-delete timestamp when set.
  lastLoginAt                   DateTime?
  createdAt                     DateTime                        @default(now())
  deletedAt                     DateTime?

}

model OAuthAccount {
  // Links a User to a third-party OAuth identity (e.g. Google): tokens and provider ids.
  privateId                     Int                             @Id @default(autoincrement())

  // User linked to this OAuth account; deleting the user cascades and removes linked OAuth rows.
  privateUserId                 Int
  user                          User                            @relation(fields: [privateUserId], references: [privateId], onDelete: Cascade)

  // Provider identity: stable ids from the OAuth vendor (e.g. provider + subject).
  providerName                  String
  providerId                    String

  // OAuth tokens for API calls; refresh is optional depending on provider.
  accessToken                   String                          @unique
  refreshToken                  String?                         @unique

  createdAt                     DateTime                        @default(now())

  // One OAuth identity per provider account globally (same Google account cannot bind twice).
  @@unique([providerName, providerId])
}


model Sessions {
  // Authenticated session for a user: tokens, device fingerprint, and expiry tracking.
  privateId                     Int                             @Id @default(autoincrement())

  // Session belongs to exactly one user; removed when user is deleted.
  privateUserId                 Int
  user                          User                            @relation(fields: [privateUserId], references: [privateId], onDelete: Cascade)

  // Bearer-style secrets used to validate requests for this session.
  accessToken                   String                          @unique
  refreshToken                  String                          @unique

  // Short label for the client (browser name, OS, etc.) for auditing and revoke UX.
  device                        String

  // Token validity window and last activity for idle-timeout policies.
  tokenExpiresAt                DateTime
  lastActiveAt                  DateTime
  createdAt                     DateTime                        @default(now())

}


enum ProofType {
  DIRECT
  CONTRADICTION
  CONTRAPOSITIVE
  WEAK_INDUCTION
  STRONG_INDUCTION
  COUNTEREXAMPLE
  STRUCTURAL_INDUCTION
  BICONDITIONAL
  CONDITIONAL
  CASE_ANALYSIS
}


model Document {
  // A proof document owned by a user: metadata, course scope, and compile/edit timestamps.
  //
  // Same dual-id pattern as User: internal key plus stable publicId for sharing links safely.
  privateId                     Int                             @Id @default(autoincrement())
  publicId                      String                          @unique @default(cuid())

  // Title and ownership; proof strategy type; optional course context when relevant.
  title                         String
  privateOwnerId                Int
  user                          User                            @relation(fields: [privateOwnerId], references: [privateId], onDelete: Cascade)
  proofType                     ProofType
  privateCourseId               Int?
  course                        Course                          @relation(fields: [privateCourseId], references: [privateId], onDelete: SetNull)

  // Soft delete and editor/compiler bookkeeping.
  deletedAt                     DateTime?
  lastCompiled                  DateTime?
  lastEdited                    DateTime                        @updatedAt
  createdAt                     DateTime                        @default(now())

  // Inverse relations: rows that reference this document’s privateId (bodies, attempts, errors, junction links).
  documentBodies                DocumentBody[]
  proofAttempts                 ProofAttempt[]
  errors                        Error[]
  documentMathStatements        documentMathStatements[]

  // Each owner may not reuse the same document title (per-user uniqueness).
  @@unique([privateOwnerId, title])
}

model DocumentBody {
  // Versioned body content for a Document: JSON payload keyed by internal ids.
  privateId                     Int                             @Id @default(autoincrement())
  publicId                      String                          @unique @default(cuid())

  // Serialized editor/proof content (structure defined by the application layer).
  content                       Json

  // Parent document this body belongs to.
  privateDocumentId             Int
  document                      Document                        @relation(fields: [privateDocumentId], references: [privateId], onDelete: Cascade)

  createdAt                     DateTime                        @default(now())

}


model ProofAttempt {
  // One saved snapshot of work on a document: content blob, optional version label, analytics.
  //
  // Identifiers mirror other entities: internal id plus share-safe publicId.
  privateId                     Int                             @id @default(autoincrement())
  publicId                      String                          @unique @default(cuid())

  // Parent document. Deletes do not cascade so attempts can be retained for analytics or ML.
  privateDocumentId             Int
  document                      Document                        @relation(fields: [privateDocumentId], references: [privateId], onDelete: SetNull)

  // Proof payload and optional named version; manualSave distinguishes autosave vs explicit save.
  content                       Json
  versionName                   String?
  manualSave                    Boolean                         @default(false)

  // Diagnostics captured with this snapshot (e.g. error counts and opaque analytics Json).
  errorCount                    Int                             @default(0)
  historicalMetadata            Json

  createdAt                     DateTime                        @default(now())
}

model Hint {
  // A hint anchored to a slice of proof content: indices, model id, resolution state.
  privateId                     Int                             @id @default(autoincrement())
  publicId                      String                          @unique @default(cuid())

  // Hint body and span inside the proof text; model identifies which assistant/model produced it.
  content                       Json
  startIndex                    Int
  endIndex                      Int
  model                         String

  // User dismissed or resolved the hint; createdAt for ordering and audits.
  resolvedAt                    DateTime?
  dismissedAt                   DateTime?
  createdAt                     DateTime                        @default(now())

  // Populated from the junction table when this hint is tied to documents/math statements.
  usageRecords                  documentMathStatements[]
}

enum ErrorTypes {
  Incorrectly Negatating a statement
  Assuming the Converse
  Equivocation
  False Dichotomy in Case Analysis
  Unjustified Reversibility
  Misapplying a Theorem
  Misapplying a Definition
  Misapplying a Lemma
  Misapplying a Property
  Misapplying a Axiom
  Misapplying a Corollary
  Misapplying a Conjecture
  Misapplying a Proposition
  Affirming the Consequent
  Circular Reasoning
  Jumping to Conclusions
  Improper Generalization
  Incorrectly Negating a Statement
}

enum Severity {
  LOW
  MODERATE
  CRITICAL
}

enum ValidationLayer {
  Latex Parser
  Computation Checker
  Proof Wording/Grammar Model
  Logic Engine
}

model Error {
  // A detected issue in a document’s proof: location, classification, severity, and lifecycle.
  privateId                     Int                             @id @default(autoincrement())
  publicId                      String                          @unique @default(cuid())

  // Character range inside the proof JSON/content that this error refers to; suggestedFix is structured guidance.
  startIndex                    Int
  endIndex                      Int
  suggestedFix                  Json

  // Owning document for navigation and permissions.
  privateDocumentId             Int
  document                      Document                        @relation(fields: [privateDocumentId], references: [privateId], onDelete: Cascade)

  // Taxonomy: kind of mistake, severity band, validation pipeline stage, and originating model id.
  type                          ErrorTypes
  severity                      Severity
  layer                         ValidationLayer
  model                         String

  resolvedAt                    DateTime?
  dismissedAt                   DateTime?
  createdAt                     DateTime                        @default(now())

}

enum Library {
  DEFINITION
  THEOREM
  LEMMA
  PROPERTY
  AXIOM
  COROLLARY
  CONJECTURE
  PROPOSITION
}

enum Textbook {
  Fuchs_102
}

model documentMathStatements {
  // Junction: connects a Document, a MathStatement, and an optional Hint with usage metadata.
  privateDocumentId             Int
  document                      Document                        @relation(fields: [privateDocumentId], references: [privateId], onDelete: Cascade)

  privateMathStatementId        Int
  mathstatement                 MathStatement                   @relation(fields: [privateMathStatementId], references: [privateId], onDelete: Cascade)

  privateHintId                 Int
  hint                          Hint                            @relation(fields: [privateHintId], references: [privateId], onDelete: Cascade)

  // Whether the hint was acted on and when it was cleared or ignored.
  wasUsed                       Boolean                         @default(false)
  resolvedAt                    DateTime?
  dismissedAt                   DateTime?
  createdAt                     DateTime                        @default(now())

  // Composite primary key over the three foreign keys.
  @@id([privateDocumentId, privateMathStatementId, privateHintId])
}

model MathStatement {
  // Reusable mathematical statement (definition, theorem, …) scoped to a course and textbook ordering.
  privateId                     Int                             @id @default(autoincrement())
  publicId                      String                          @unique @default(cuid())

  // Classification, display name, formal content; course ties statements to a curriculum; textbook and order for sorting.
  type                          Library
  name                          String
  content                       Json
  privateCourseId               Int
  course                        Course                          @relation(fields: [privateCourseId], references: [privateId], onDelete: Cascade)
  textbook                      Textbook
  orderIndex                    Int

  // Reverse relation: where this statement appears across documents (via junction table).
  usageInDocs                   documentMathStatements[]

  createdAt                     DateTime                        @default(now())
}

model userCourse {
  // Enrollment of a User in a Course; supports soft unenroll via timestamp.
  privateUserId                 Int
  user                          User                            @relation(fields: [privateUserId], references: [privateId], onDelete: Cascade)

  privateCourseId               Int
  course                        Course                          @relation(fields: [privateCourseId], references: [privateId], onDelete: Cascade)

  unenrolledAt                  DateTime?
  createdAt                     DateTime                        @default(now())

  @@id([privateUserId, privateCourseId])
}

enum Country {
  CANADA
}

model Course {
  // Course offering under one university: documents and statements hang off this row.
  privateId                     Int                             @id @default(autoincrement())
  publicId                      String                          @unique @default(cuid())

  // Human-readable name; belongs to exactly one university for multi-tenant isolation.
  name                          String
  universityId                  Int
  university                    University                      @relation(fields: [universityId], references: [privateId], onDelete: Cascade)

  // Inverse relations for Prisma navigation (not extra columns).
  documents                     Document[]
  mathStatements                MathStatement[]
  enrollments                   userCourse[]

  // Course titles need only be unique within a university (not globally).
  @@unique([universityId, name])

  createdAt                     DateTime                        @default(now())
}

model University {
  // Tenant root: branding and geography; aggregates users and courses for that institution.
  privateId                     Int                             @id @default(autoincrement())
  publicId                      String                          @unique @default(cuid())

  name                          String
  logoUrl                       String
  country                       Country

  // All users and courses that belong to this university (multi-tenant boundaries).
  users                         User[]
  courses                       Course[]

  createdAt                     DateTime                        @default(now())
}

enum PlanTier {
  FREE
  PRO
  ULTIMATTE
}

enum ErrorTypes {
  // Surface-level grammar and wording checks only.
  PROOF_GRAMMER
  // Grammar plus computational step validation (e.g. arithmetic).
  COMPUTATION
  // Full pipeline including logical consistency of the proof chain.
  LOGIC_CHAIN
}

model Plan {
  // Sellable subscription tier: pricing flags and per-day limits surfaced to the product.
  id                            Int                             @Id @default(autoincrement())
  name                          PlanTier                        @unique
  monthlyPrice                  Decimal                         @default(0.0)
  isActive                      Boolean                         @default(true)

  // Usage caps enforced by the app: documents per day, hints per definition, suggestions per proof,
  // and which class of proof errors the user is allowed to see (tier-gated feedback).
  dailyDocLimit                 Int
  hintsPerDefLimit              Int
  suggestionLimit               Int
  errorVisibility               ErrorTypes

  createdAt                     DateTime                        @default(now())

  // Inverse relation: subscriptions that reference this plan row.
  subscriptions                 Subscription[]
}


model DailyUsage {
  // Per-user daily counters for quota enforcement (resets per calendar rules in application code).
  privateId                     Int                             @Id @default(autoincrement())
  publicId                      String                          @unique @default(cuid())

  // Which user’s usage row this is; cascades with user deletion.
  privateUserId                 Int
  user                          User                            @relation(fields: [privateUserId], references[privateId], onDelete: Cascade)

  // Rolling counters within the row’s logical “day” (document creates, suggestion consumption).
  docsCreatedToday              Int                             @default(0)
  suggestionsUsedToday          Int                             @default(0)

  date                          DateTime                        @default(now())
  createdAt                     DateTime                        @default(now())

  // At most one usage aggregate per user per date value (unique pair).
  @@unique([privateUserId, date])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

model Subscription {
  // Links a user to a billing Plan with processor ids and renewal window.
  privateId                     Int                             @Id @default(autoincrement())
  publicId                      String                          @unique @default(cuid())

  // Subscriber and chosen plan; plan delete sets FK null so subscription history can remain.
  userId                        Int
  user                          User                            @relation(fields: [userId], references: [privateId], onDelete: Cascade)

  planId                        Int
  plan                          Plan                            @relation(fields: [planId], references: [privateId], onDelete: SetNull)

  // Billing lifecycle flags from your provider integration.
  status                        SubscriptionStatus
  cancelAtPeriodEnd             Boolean

  // External subscription id from the payment provider (e.g. Stripe) for webhooks and reconciliation.
  processorSubscriptionId       string

  // When the current paid period ends (renewal / cancellation semantics in app code).
  currentPeriodEnd              DateTime
}
