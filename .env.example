# Copy to `.env` at the repo root and fill in secrets. Docker Compose reads this file
# via `env_file: .env`. For host-native dev, use localhost in DATABASE_URL; Compose
# overrides DATABASE_URL for `web` and `websocket` to use hostname `postgres`.

# --- Database (Prisma / apps) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# --- URLs (no trailing slash; used for JWT issuer/audience alignment) ---
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=http://localhost:3001

# --- Auth (generate strong random values for production; min 32 chars for JWT secrets) ---
REFRESH_TOKEN_JWT_SECRET=replace_with_a_random_string_at_least_32_characters_long
REFRESH_TOKEN_EXPIRES_IN=30d
ACCESS_TOKEN_JWT_SECRET=replace_with_another_random_string_at_least_32_chars
ACCESS_TOKEN_EXPIRES_IN=5m
BCRYPT_SALT_ROUNDS=10

# --- ML worker (`apps/ml`, pydantic-settings) ---
QUESTION_ANALYSIS_MODEL=gemini
BODY_ANALYSIS_MODEL=gemini
SENTENCE_ANALYSIS_MODEL=gemini
GEMINI_API_KEY=

# --- Redis (TCP; used by websocket, ML, helpers) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Rate limiting (web; optional when RATE_LIMIT_DISABLED=true) ---
RATE_LIMIT_DISABLED=false
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Postgres container defaults (docker-compose `postgres` service) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
# Hostname for services that run inside Docker and reach Postgres by service name.
DB_HOST=postgres

# --- Optional integrations (web `envSchema` defaults to empty) ---
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# RESEND_API_KEY=

# --- Optional product / signup defaults ---
# NEXT_PUBLIC_UOFT_UNIVERSITY_ID=
